SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=.onrender.com,localhost,127.0.0.1
DATABASE_URL=postgresql://user:password@host:5432/refereepoint

# Set this to your frontend URL in production.
FRONTEND_URL=https://your-frontend.onrender.com

# Optional explicit CORS/CSRF lists (comma-separated).
# If unset, FRONTEND_URL + localhost defaults are used.
CORS_ALLOWED_ORIGINS=https://your-frontend.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-frontend.onrender.com

# Keep false in production.
CORS_ALLOW_ALL_ORIGINS=False
ENABLE_DEV_AUTO_LOGIN=False
